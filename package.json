{
  "name": "p2p-lockstep-kit-multisession",
  "version": "0.1.0",
  "description": "Deterministic multi-participant P2P session core for turn-based games.",
  "license": "GPL-3.0-only",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "docs",
    "README.md",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "playground:dev": "pnpm --dir playground dev",
    "playground:build": "pnpm --dir playground build",
    "playground:test": "pnpm --dir playground test",
    "pack:check": "node scripts/package-smoke.mjs",
    "integration:network": "node scripts/network-integration-smoke.mjs"
  },
  "dependencies": {
    "p2p-lockstep-kit-network": "^0.1.4"
  },
  "devDependencies": {
    "tsup": "^8.5.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.2"
  },
  "packageManager": "pnpm@11.7.0"
}
